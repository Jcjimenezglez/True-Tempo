{
  "version": 2,
  "headers": [
    {
      "source": "/audio/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/callback",
      "destination": "/"
    }
  ],
  "redirects": [
    {
      "source": "/pomodoro-timer",
      "destination": "https://www.superfocus.live/techniques/pomodoro-technique",
      "permanent": true
    },
    {
      "source": "/focus-timer",
      "destination": "https://www.superfocus.live/",
      "permanent": true
    },
    {
      "source": "/work-timer",
      "destination": "https://www.superfocus.live/use-cases/work-timer",
      "permanent": true
    },
    {
      "source": "/study-timer",
      "destination": "https://www.superfocus.live/use-cases/study-timer",
      "permanent": true
    },
    {
      "source": "/time-management",
      "destination": "https://www.superfocus.live/techniques/time-blocking-timer",
      "permanent": true
    },
    {
      "source": "/productivity-app",
      "destination": "https://www.superfocus.live/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "superfocus.live" }],
      "destination": "https://www.superfocus.live/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "truetempo.app" }],
      "destination": "https://www.superfocus.live/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.truetempo.app" }],
      "destination": "https://www.superfocus.live/$1",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "destination": "/terms",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/sync-premium-status",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/build-premium-leaderboard",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-cassette-metadata",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/demote-low-activity-cassettes",
      "schedule": "0 4 * * 0"
    }
  ]
}